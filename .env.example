# --- LLM Configuration ---

# Default is http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# The model name you pulled (e.g., llama3.1, mistral-large-3:675b-cloud)
OLLAMA_MODEL=llama3.1


# --- Search API Keys (At least one is recommended) ---
# Get a key at https://tavily.com/
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxx


# Fallback Search (Get a key at https://serper.dev/)
SERPER_API_KEY=your_serper_api_key_here


# --- Logging & Debugging ---
# Set to 'true' to see detailed LangGraph traces
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=ls__xxxxxxxxxxxxxxxxxxxxxxxx
