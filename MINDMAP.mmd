graph TD
    A[LangGraph Code Analysis Agent] --> B[State Management]
    A --> C[Tool System]
    A --> D[Node Pipeline]
    A --> E[Workflow Execution]
    
    B --> B1[AgentState TypedDict]
    B1 --> B2["folder_path: str"]
    B1 --> B3["files: List[str]"]
    B1 --> B4["file_summaries: Dict[str, str]"]
    B1 --> B5["research_context: str"]
    B1 --> B6["final_docs: Dict[str, str]"]
    
    C --> C1[FileReadTool]
    C1 --> C2[Reads files with UTF-8 encoding]
    C1 --> C3[Error handling for encoding issues]
    
    C --> C4[SearchTool]
    C4 --> C5[Tavily API integration]
    C4 --> C6[Fallback to WebSearchTool]
    
    C --> C7[WebSearchTool]
    C7 --> C8[Google Serper API integration]
    C7 --> C9[Requires SERPER_API_KEY]
    
    D --> D1[indexer_node]
    D1 --> D2[Scans target directory]
    D2 --> D3[Excludes .git directories]
    D2 --> D4[Collects file paths]
    
    D --> D5[analyst_node]
    D5 --> D6[Processes each file]
    D6 --> D7[Uses FileReadTool]
    D6 --> D8[Calls Ollama LLM]
    D8 --> D9[llama3.1 model]
    D8 --> D10[Extracts suspicious patterns]
    
    D --> D11[researcher_node]
    D11 --> D12[Triggers on suspicious terms]
    D12 --> D13[Uses SearchTool/WebSearchTool]
    D13 --> D14[External threat intelligence]
    
    D --> D15[writer_node]
    D15 --> D16[Generates three report types]
    D16 --> D17[comprehensive_report.md]
    D16 --> D18[threat_report.md]
    D16 --> D19[executive_summary.md]
    
    E --> E1["compile_graph()"]
    E1 --> E2[Creates StateGraph]
    E2 --> E3[Adds nodes in sequence]
    E3 --> E4["indexer → analyst → researcher → writer"]
    
    E --> E5["invoke_agent()"]
    E5 --> E6[Entry point function]
    E6 --> E7[Validates folder path]
    E7 --> E8[Initializes AgentState]
    E8 --> E9[Executes graph workflow]
    E9 --> E10[Returns final documentation]
